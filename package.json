{
  "name": "surgeon-ai",
  "version": "0.2.0",
  "description": "AI-Powered Codebase Audit & Repair CLI",
  "type": "module",
  "bin": {
    "srgn": "./dist/srgn.js",
    "surgeon-ai": "./dist/srgn.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "publisher": "pnpm publish"
  },
  "keywords": [
    "audit",
    "codebase",
    "security",
    "ai",
    "claude",
    "code-review",
    "cli"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "eslint": "^10.3.0",
    "fast-glob": "^3.3.3",
    "ink": "^7.0.2",
    "ora": "^9.4.0",
    "p-limit": "^7.3.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "simple-git": "^3.36.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5",
    "zod": "^4.4.3"
  }
}
